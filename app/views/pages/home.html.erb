<% meta title: "BVI Cruise Ship Schedule — Tortola Cruise Port & Crowd Tracker",
       description: "Check the BVI cruise ship schedule for Tortola, Virgin Gorda, and Jost Van Dyke. See which ships are in port, passenger counts, and hourly crowd risk levels at The Baths and White Bay.",
       keywords: "bvi cruise ship schedule, tortola cruise ship schedule, tortola cruise port, british virgin islands cruise ship schedule, tortola cruise port schedule, bvi cruise schedule, the baths bvi crowded, road town cruise ships" %>
<% meta og: { title: "BVI Cruise Ship Schedule & Crowd Tracker",
              description: "Track cruise ships visiting the BVI and check hourly crowd risk at The Baths and White Bay. Plan your charter day around the crowds.",
              type: "website",
              image: image_url("the-baths-4.jpg") } %>
<% meta twitter: { card: "summary_large_image",
                   title: "BVI Cruise Ship Schedule & Crowd Tracker",
                   description: "Track cruise ships visiting the BVI and check hourly crowd risk at The Baths and White Bay.",
                   image: image_url("the-baths-4.jpg") } %>

<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "BVI Cruise Ship Schedule",
  "description": "Track cruise ships visiting the British Virgin Islands. See hourly crowd risk levels at The Baths and White Bay based on ship schedules, passenger counts, and arrival times.",
  "url": "https://bvicruiseshipschedule.com/",
  "applicationCategory": "TravelApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "about": [
    { "@type": "TouristAttraction", "name": "The Baths National Park", "address": { "@type": "PostalAddress", "addressLocality": "Virgin Gorda", "addressRegion": "British Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "White Bay", "address": { "@type": "PostalAddress", "addressLocality": "Jost Van Dyke", "addressRegion": "British Virgin Islands" } }
  ]
}
</script>
<% end %>

<%# Hero — full width with background image %>
<div class="relative isolate overflow-hidden">
  <%= image_tag "the-baths-3.jpg", class: "absolute inset-0 -z-10 size-full object-cover brightness-50", alt: "The Baths, Virgin Gorda BVI" %>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32 text-center">
    <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-6xl">BVI Cruise Ship Schedule</h1>
    <p class="mt-6 text-lg font-medium text-gray-300 sm:text-xl/8">
      We look at how many cruise ships are in town, how many passengers they carry, and their arrival and departure
      times to give you our best estimate of when <strong class="text-white">The Baths</strong>,
      <strong class="text-white">White Bay</strong>, and <strong class="text-white">Cane Garden Bay</strong> are most likely to be crowded — so you can plan around it.
    </p>
    <div class="mt-8 flex items-center justify-center gap-x-4">
      <a href="#schedule" class="rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400">View Schedule</a>
      <a href="#how-it-works" class="text-sm font-semibold text-white">How it works <span aria-hidden="true">→</span></a>
    </div>
  </div>
</div>

<div class="mx-auto max-w-3xl px-4 mt-8 mb-8">

<%# How to read this %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6">
  <h3 class="text-sm font-semibold text-slate-700 mb-3">How to Read the Hourly Timeline</h3>
  <p class="text-xs text-slate-500 mb-3">Each box below represents one hour. The color tells you the expected crowd level from cruise ship visitors at that time.</p>
  <div class="grid grid-cols-3 gap-3 text-center">
    <div class="rounded-lg bg-emerald-50 border border-emerald-200 px-3 py-2">
      <div class="w-full h-2 rounded-full bg-emerald-400 mb-1.5"></div>
      <div class="text-sm font-semibold text-emerald-700">Low</div>
      <div class="text-xs text-emerald-600 mt-0.5">Few or no cruise ship visitors expected.</div>
    </div>
    <div class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2">
      <div class="w-full h-2 rounded-full bg-amber-400 mb-1.5"></div>
      <div class="text-sm font-semibold text-amber-700">Moderate</div>
      <div class="text-xs text-amber-600 mt-0.5">Expect cruise ship visitors but shouldn't be overwhelming.</div>
    </div>
    <div class="rounded-lg bg-red-50 border border-red-200 px-3 py-2">
      <div class="w-full h-2 rounded-full bg-red-500 mb-1.5"></div>
      <div class="text-sm font-semibold text-red-700">High</div>
      <div class="text-xs text-red-600 mt-0.5">Expect large crowds. Consider going early, late, or picking another day.</div>
    </div>
  </div>
</div>

<%# Rolling stats comparison — only show when we have enough data %>
<% if @cruise_stats && @cruise_stats[:last_30][:ships] >= 5 %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6">
  <div class="grid grid-cols-2 gap-4">
    <%# Last 7 days %>
    <div>
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Last 7 Days</div>
      <div class="text-xl font-bold text-slate-900"><%= number_with_delimiter(@cruise_stats[:last_7][:guests]) %></div>
      <div class="text-xs text-slate-400"><%= @cruise_stats[:last_7][:ships] %> ships</div>
      <% if @cruise_stats[:last_7_ly][:guests] > 0 %>
        <% change_7 = ((@cruise_stats[:last_7][:guests] - @cruise_stats[:last_7_ly][:guests]).to_f / @cruise_stats[:last_7_ly][:guests] * 100).round(0) %>
        <div class="text-xs mt-1 <%= change_7 >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
          <%= change_7 >= 0 ? "+" : "" %><%= change_7 %>% vs last year
        </div>
      <% end %>
    </div>

    <%# Last 30 days %>
    <div>
      <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Last 30 Days</div>
      <div class="text-xl font-bold text-slate-900"><%= number_with_delimiter(@cruise_stats[:last_30][:guests]) %></div>
      <div class="text-xs text-slate-400"><%= @cruise_stats[:last_30][:ships] %> ships</div>
      <% if @cruise_stats[:last_30_ly][:guests] > 0 %>
        <% change_30 = ((@cruise_stats[:last_30][:guests] - @cruise_stats[:last_30_ly][:guests]).to_f / @cruise_stats[:last_30_ly][:guests] * 100).round(0) %>
        <div class="text-xs mt-1 <%= change_30 >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
          <%= change_30 >= 0 ? "+" : "" %><%= change_30 %>% vs last year
        </div>
      <% end %>
    </div>
  </div>
  <div class="text-[10px] text-slate-300 mt-2">Cruise guest capacity — compared to same calendar period last year</div>
</div>
<% end %>

<%# USVI cross-link %>
<div class="bg-gradient-to-r from-blue-50 to-cyan-50 rounded-xl border border-blue-200 p-4 mb-6">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-blue-900">Also visiting the USVI?</p>
      <p class="text-xs text-blue-700">Track cruise ship crowds at Magens Bay, Coki Beach, and more on St. Thomas and St. Croix.</p>
    </div>
    <%= link_to "USVI Schedule →", usvi_path, class: "shrink-0 rounded-md bg-blue-600 px-3 py-2 text-xs font-semibold text-white hover:bg-blue-500 transition" %>
  </div>
</div>

<%= turbo_frame_tag "schedule" do %>
<div id="schedule"></div>
<%# Week navigation %>
<div class="flex items-center justify-between mb-4">
  <%= link_to root_path(start_date: @prev_week_start), class: "inline-flex items-center px-3 py-2 text-sm font-medium text-slate-700 bg-white rounded-lg border border-slate-200 hover:bg-slate-50 transition" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Prev
  <% end %>

  <div class="text-center">
    <h2 class="text-lg font-semibold text-slate-900">
      <%= @start_date.strftime("%b %-d") %> – <%= @end_date.strftime("%b %-d, %Y") %>
    </h2>
    <% if @start_date == @today %>
      <p class="text-xs text-cyan-600 font-medium">Next 7 Days</p>
    <% else %>
      <%= link_to "Back to Today", root_path, class: "text-xs text-cyan-600 hover:text-cyan-700 font-medium" %>
    <% end %>
  </div>

  <%= link_to root_path(start_date: @next_week_start), class: "inline-flex items-center px-3 py-2 text-sm font-medium text-slate-700 bg-white rounded-lg border border-slate-200 hover:bg-slate-50 transition" do %>
    Next
    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  <% end %>
</div>

<%# Jump to date %>
<div class="mb-6 text-center">
  <%= form_with url: root_path, method: :get, class: "inline-flex items-center gap-2" do |f| %>
    <%= f.date_field :start_date, value: @start_date, class: "text-sm border border-slate-200 rounded-lg px-3 py-1.5 text-slate-700 focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
    <%= f.submit "Go", class: "px-3 py-1.5 text-sm font-medium text-white bg-cyan-500 rounded-lg hover:bg-cyan-600 cursor-pointer transition" %>
  <% end %>
</div>

<%# Day cards %>
<div class="space-y-5">
  <% @dates.each do |date| %>
    <% visits = @visits_by_date[date] || [] %>
    <% is_today = date == @today %>

    <div class="bg-white rounded-xl shadow-sm border <%= is_today ? 'border-cyan-300 ring-2 ring-cyan-100' : 'border-slate-200' %> overflow-hidden">

      <%# Day header %>
      <div class="px-4 pt-4 <%= is_today ? 'bg-cyan-50/50' : '' %>">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="text-center min-w-[3rem]">
              <div class="text-xs font-medium text-slate-500 uppercase"><%= date.strftime("%a") %></div>
              <div class="text-2xl font-bold <%= is_today ? 'text-cyan-600' : 'text-slate-900' %>"><%= date.day %></div>
              <% if is_today %>
                <div class="text-[10px] font-semibold text-cyan-600 uppercase">Today</div>
              <% end %>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-700"><%= date.strftime("%B %-d, %Y") %></div>
            </div>
          </div>

          <%# Ship count and passenger count — prominent and labeled %>
          <% if visits.any? %>
            <div class="text-right">
              <div class="text-3xl font-bold text-slate-900"><%= number_with_delimiter(total_passengers_for(visits)) %></div>
              <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Cruise Guests</div>
              <div class="text-xs text-slate-400"><%= visits.size %> ship<%= visits.size == 1 ? '' : 's' %> in port</div>
            </div>
          <% else %>
            <div class="text-right">
              <div class="text-sm font-medium text-slate-400">No planned visits</div>
              <div class="text-xs text-slate-400">Schedule may not be available yet</div>
            </div>
          <% end %>
        </div>

        <%# Port breakdown — ship names visible %>
        <% if visits.any? %>
          <div class="flex flex-wrap gap-x-4 gap-y-1 mb-3 text-xs text-slate-500">
            <% visits.group_by { |v| v.port.name }.each do |port_name, port_visits| %>
              <span>
                <span class="font-medium text-slate-600"><%= port_name.sub(', Tortola', '').sub(', Virgin Gorda', '') %>:</span>
                <%= port_visits.map { |v| "#{v.ship_name} (#{number_with_delimiter(v.passenger_capacity || 0)})" }.join(', ') %>
              </span>
            <% end %>
          </div>
        <% end %>

        <%# Location risk sections %>
        <% @locations.each do |location| %>
          <% snapshots = @snapshots[[date, location.id]] || [] %>
          <% peak = peak_intensity_for(snapshots) %>


          <% location_icon = case location.slug; when Location::THE_BATHS then "🪨"; when Location::WHITE_BAY then "🏖️"; when Location::CANE_GARDEN_BAY then "🌴"; else "📍"; end %>
          <div class="mb-4 last:mb-3 rounded-lg border border-slate-100 p-3 <%= intensity_bg_light(peak) %>">
            <%# Location header with icon and risk badge %>
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center gap-2">
                <span class="text-lg"><%= location_icon %></span>
                <h4 class="text-base font-bold text-slate-800"><%= location.name %></h4>
              </div>
              <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold <%= intensity_color_class(peak) %> text-white">
                <%= peak == "green" ? "Low Risk" : peak == "yellow" ? "Moderate" : "High Risk" %>
              </span>
            </div>

            <%# Hourly timeline with EVERY hour labeled %>
            <div>
              <div>
                <div class="grid gap-px" style="grid-template-columns: repeat(11, minmax(0, 1fr))">
                  <% (7..17).each do |hour| %>
                    <% snapshot = snapshots.find { |s| s.hour == hour } %>
                    <% intensity = snapshot&.intensity || "green" %>
                    <% visitors = snapshot&.estimated_visitors || 0 %>

                    <div class="text-center">
                      <div class="h-8 rounded <%= intensity_color_class(intensity) %> cursor-default"
                           title="<%= format_hour(hour) %> — <%= case intensity; when 'red' then 'High risk'; when 'yellow' then 'Moderate risk'; else 'Low risk'; end %>">
                      </div>
                      <div class="text-[9px] text-slate-400 mt-1 leading-tight"><%= format_hour_short(hour) %></div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <%# Yacht Warriors CTA — only on moderate/high crowd days %>
        <% day_peak = day_peak_intensity(date, @locations, @snapshots) %>
        <% if day_peak.in?(%w[yellow red]) %>
          <div class="mx-4 mb-4 rounded-lg border border-cyan-200 bg-cyan-50 px-4 py-3 flex items-center justify-between gap-3">
            <div>
              <% if day_peak == "red" %>
                <p class="text-sm font-medium text-cyan-900">Big cruise day ahead</p>
                <p class="text-xs text-cyan-700">Skip the crowds entirely with a private yacht charter.</p>
              <% else %>
                <p class="text-sm font-medium text-cyan-900">Planning around the crowds?</p>
                <p class="text-xs text-cyan-700">A private charter gives you the flexibility to explore on your schedule.</p>
              <% end %>
            </div>
            <a href="https://yachtwarriors.com?utm_source=bvicruise&utm_medium=web&utm_campaign=crowd_cta&utm_content=<%= day_peak %>"
               target="_blank" rel="noopener"
               class="shrink-0 rounded-md bg-cyan-600 px-3 py-2 text-xs font-semibold text-white hover:bg-cyan-500 transition">
              Yacht Warriors →
            </a>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<% end %>

<%# About section %>
<div id="how-it-works" class="mt-8 bg-white rounded-xl shadow-sm border border-slate-200 p-5">
  <h3 class="text-sm font-semibold text-slate-700 mb-2">How does this work?</h3>
  <div class="text-sm text-slate-500 space-y-2">
    <p>
      We pull published cruise ship schedules daily — ship names, passenger capacity, arrival and departure times,
      and which BVI port they're visiting. Then we estimate hourly crowd levels at The Baths, White Bay, and
      Cane Garden Bay throughout each day.
    </p>
    <p>
      <strong>The Baths</strong> gets cruise traffic from ships at Spanish Town (Virgin Gorda) sending passengers
      directly, ships at Road Town (Tortola) selling Baths excursions via ferry, and occasionally from ships
      anchored in North Sound/Gorda Sound — though that's relatively minor.
      <strong>White Bay</strong> gets hit when ships anchor at Jost Van Dyke.
      <strong>Cane Garden Bay</strong> is on Tortola and a short taxi ride from the cruise ship terminal in Road Town,
      so any time there are large ships in town it's likely to be busy.
    </p>
    <p>
      These are estimates based on published schedules and ship capacity. Real crowd levels depend on weather, excursion bookings,
      and actual occupancy. Use this as a planning tool — check the hourly bars and aim for green windows.
    </p>
  </div>
</div>

