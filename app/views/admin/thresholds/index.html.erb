<h1 class="text-2xl font-bold text-gray-900 mb-6">Crowd Thresholds</h1>
<p class="text-sm text-slate-500 mb-6">Set the visitor count boundaries for green/yellow/red crowd levels at each location.</p>

<div class="space-y-4">
  <% @thresholds.each do |threshold| %>
    <div class="bg-white rounded-lg shadow-sm p-6">
      <h3 class="text-lg font-semibold text-gray-900 mb-4"><%= threshold.location.name %></h3>

      <%= form_with model: threshold, url: admin_threshold_path(threshold), method: :patch, class: "space-y-4" do |f| %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">
              <span class="inline-block w-3 h-3 rounded-full bg-emerald-400 mr-1"></span>
              Green Max (visitors)
            </label>
            <%= f.number_field :green_max, class: "w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500", min: 0 %>
            <p class="text-xs text-slate-400 mt-1">Up to this many = green (low crowd)</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1">
              <span class="inline-block w-3 h-3 rounded-full bg-amber-400 mr-1"></span>
              Yellow Max (visitors)
            </label>
            <%= f.number_field :yellow_max, class: "w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500", min: 0 %>
            <p class="text-xs text-slate-400 mt-1">Up to this many = yellow. Above = red.</p>
          </div>
        </div>
        <%= f.submit "Save", class: "px-4 py-2 bg-cyan-500 text-white rounded-lg hover:bg-cyan-600 text-sm font-medium cursor-pointer transition" %>
      <% end %>
    </div>
  <% end %>
</div>
