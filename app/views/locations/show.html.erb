<% config = location_config_for(@location.slug) %>

<% meta title: config[:title],
       description: config[:description],
       keywords: config[:keywords] %>
<% meta og: { title: config[:og_title],
              description: config[:description],
              type: "website",
              image: image_url(config[:hero_image]) } %>

<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "<%= @location.name %>",
  "description": "<%= config[:description] %>",
  "url": "https://bvicruiseshipschedule.com/<%= @location.slug %>"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= root_url %>" },
    { "@type": "ListItem", "position": 2, "name": "<%= config[:territory] == 'bvi' ? 'BVI Schedule' : 'USVI Schedule' %>", "item": "<%= config[:territory] == 'bvi' ? root_url : usvi_url %>" },
    { "@type": "ListItem", "position": 3, "name": "<%= config[:port_name] %>", "item": "<%= send(:"#{config[:port_route]}_url") %>" },
    { "@type": "ListItem", "position": 4, "name": "<%= @location.name %>", "item": "<%= send(:"#{config[:route_name]}_url") %>" }
  ]
}
</script>
<% end %>

<%# Hero — crowd risk as dominant visual %>
<div class="relative isolate overflow-hidden">
  <%= image_tag config[:hero_image], class: "absolute inset-0 -z-10 size-full object-cover", alt: config[:hero_alt] %>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-900/60 via-slate-900/45 to-slate-950/80"></div>
  <div class="mx-auto max-w-3xl px-6 py-16 sm:py-24 text-center">
    <h1 class="text-3xl font-semibold tracking-tight text-balance text-white sm:text-5xl"><%= @location.name %></h1>
    <p class="mt-2 text-sm text-gray-200">Cruise Ship Crowd Forecast</p>

    <%# Today's crowd risk — the hero element %>
    <div class="mt-8 mx-auto max-w-lg">
      <% if @today_visits.any? %>
        <div class="rounded-xl p-5 <%= case @today_peak; when 'red' then 'bg-red-500/90'; when 'yellow' then 'bg-amber-500/90'; else 'bg-emerald-500/90'; end %>">
          <div class="text-2xl font-bold text-white">
            <%= case @today_peak
                when "red" then "High Risk"
                when "yellow" then "Moderate Risk"
                else "Low Risk"
                end %>
          </div>
          <p class="mt-1 text-sm text-white/90">
            <%= @today_visits.size %> ship<%= @today_visits.size == 1 ? '' : 's' %> in port today carrying
            <%= number_with_delimiter(@today_passengers) %> passengers
          </p>
          <% if @best_time %>
            <p class="mt-2 text-sm font-semibold text-white">Best time to visit: <%= @best_time %></p>
          <% end %>
        </div>
      <% else %>
        <div class="rounded-xl bg-emerald-500/90 p-5">
          <div class="text-2xl font-bold text-white">No Cruise Ships Today</div>
          <p class="mt-1 text-sm text-white/90">No cruise ships are scheduled to visit today. Enjoy!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="mx-auto max-w-3xl px-4 mt-8 mb-8">

<%# Today's hourly timeline — prominent %>
<% if @today_snapshots.any? %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6">
  <h3 class="text-sm font-semibold text-slate-700 mb-3">Today's Hourly Forecast</h3>
  <%= render "shared/location_card", location: @location, snapshots: @today_snapshots, peak: @today_peak %>
</div>
<% end %>

<%# Contributing ships today %>
<% if @today_visits.any? %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6">
  <h3 class="text-sm font-semibold text-slate-700 mb-3">Ships Contributing to Crowds Today</h3>
  <div class="space-y-2">
    <% @today_visits.each do |visit| %>
      <div class="flex items-center justify-between text-sm">
        <div>
          <span class="font-medium text-slate-700"><%= visit.ship_name %></span>
          <span class="text-xs text-slate-400 ml-1">at <%= visit.port.name.sub(', Tortola', '').sub(', Virgin Gorda', '').sub(', St. Thomas', '').sub(', St. Croix', '') %></span>
        </div>
        <span class="text-xs font-medium text-slate-500"><%= number_with_delimiter(visit.passenger_capacity || 0) %> passengers</span>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%= render "shared/timeline_legend" %>

<%# Cross-links %>
<div class="flex gap-3 mb-6">
  <%= link_to "← #{@contributing_ports.first&.name || 'Port'} Schedule", send(:"#{config[:port_route]}_path"), class: "text-xs font-medium text-cyan-600 hover:text-cyan-700" %>
  <% if config[:territory] == "bvi" %>
    <%= link_to "BVI Schedule", root_path, class: "text-xs font-medium text-cyan-600 hover:text-cyan-700" %>
  <% else %>
    <%= link_to "USVI Schedule", usvi_path, class: "text-xs font-medium text-cyan-600 hover:text-cyan-700" %>
  <% end %>
</div>

<%# 7-day forecast %>
<%= turbo_frame_tag "schedule" do %>
<div id="schedule"></div>

<% page_path = send(:"#{config[:route_name]}_path") %>
<%= render "shared/week_navigation",
  prev_url: send(:"#{config[:route_name]}_path", start_date: @prev_week_start),
  next_url: send(:"#{config[:route_name]}_path", start_date: @next_week_start),
  today_url: page_path,
  form_url: page_path,
  start_date: @start_date,
  end_date: @end_date,
  today: @today %>

<div class="space-y-3">
  <% @dates.each do |date| %>
    <% visits = @visits_by_date[date] || [] %>
    <% snapshots = @snapshots_by_date[date] || [] %>
    <% peak = peak_intensity_for(snapshots) %>
    <% is_today = date == @today %>

    <div class="bg-white rounded-xl shadow-sm border <%= is_today ? 'border-cyan-300 ring-2 ring-cyan-100' : 'border-slate-200' %> <%= "border-l-4 #{intensity_border_class(peak)}" if visits.any? %> p-4">
      <div class="flex items-center justify-between mb-2">
        <div class="flex items-center gap-3">
          <div class="text-center min-w-[3rem]">
            <div class="text-xs font-medium text-slate-500 uppercase"><%= date.strftime("%a") %></div>
            <div class="text-xl font-bold <%= is_today ? 'text-cyan-600' : 'text-slate-900' %>"><%= date.day %></div>
            <% if is_today %>
              <div class="text-[10px] font-semibold text-cyan-600 uppercase">Today</div>
            <% end %>
          </div>
          <div>
            <div class="text-sm font-medium text-slate-700"><%= date.strftime("%B %-d, %Y") %></div>
            <% if visits.any? %>
              <div class="text-xs text-slate-400"><%= visits.size %> ship<%= visits.size == 1 ? '' : 's' %>, <%= number_with_delimiter(total_passengers_for(visits)) %> passengers</div>
            <% else %>
              <div class="text-xs text-slate-400">No ships scheduled</div>
            <% end %>
          </div>
        </div>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold <%= intensity_color_class(peak) %> text-white">
          <%= peak == "green" ? "Low Risk" : peak == "yellow" ? "Moderate" : "High Risk" %>
        </span>
      </div>

      <% if snapshots.any? %>
        <div class="grid gap-px" style="grid-template-columns: repeat(11, minmax(0, 1fr))">
          <% (7..17).each do |hour| %>
            <% snapshot = snapshots.find { |s| s.hour == hour } %>
            <% intensity = snapshot&.intensity || "green" %>
            <div class="text-center">
              <div class="h-6 rounded <%= intensity_color_class(intensity) %> cursor-default"
                   title="<%= format_hour(hour) %> — <%= case intensity; when 'red' then 'High risk'; when 'yellow' then 'Moderate risk'; else 'Low risk'; end %>">
              </div>
              <div class="text-[9px] text-slate-400 mt-0.5 leading-tight"><%= format_hour_short(hour) %></div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
<% end %>

<%# About section %>
<div class="mt-6 bg-white rounded-xl shadow-sm border border-slate-200 p-5">
  <h3 class="text-sm font-semibold text-slate-700 mb-2">About <%= @location.name %></h3>
  <div class="text-sm text-slate-500 space-y-2">
    <p><%= config[:about] %></p>
    <p>Crowd estimates are based on published cruise ship schedules, passenger capacity, and arrival/departure times. Real crowd levels depend on weather, excursion bookings, and actual occupancy.</p>
  </div>
</div>

<%= render "shared/footer_attribution", utm_campaign: "footer_yw_#{config[:route_name]}" %>

</div>
