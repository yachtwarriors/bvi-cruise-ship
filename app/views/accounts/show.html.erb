<div class="mx-auto max-w-md px-4 mt-12 mb-12">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-xl font-bold text-slate-900 mb-1">My Account</h2>
    <p class="text-sm text-slate-500 mb-6"><%= @user.email %></p>

    <% if flash[:notice] %>
      <div class="rounded-lg bg-emerald-50 border border-emerald-200 p-3 mb-4">
        <p class="text-sm text-emerald-700"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <h3 class="text-base font-semibold text-slate-800 mb-2">Daily Crowd Alerts</h3>
    <p class="text-sm text-slate-500 mb-4">Set the dates you'll be in the BVI and we'll email you a morning crowd report each day.</p>

    <%= form_with model: @user, url: account_path, method: :patch, class: "space-y-4" do |f| %>
      <% if @user.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-3">
          <% @user.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-700"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="user_alert_start_date" class="block text-sm font-medium text-slate-700 mb-1">Start Date</label>
          <%= f.date_field :alert_start_date, class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
        </div>
        <div>
          <label for="user_alert_end_date" class="block text-sm font-medium text-slate-700 mb-1">End Date</label>
          <%= f.date_field :alert_end_date, class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= f.submit "Save Dates", class: "rounded-md bg-cyan-500 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400 cursor-pointer transition" %>
        <% if @user.alert_start_date.present? %>
          <%= button_to "Remove Alerts", account_path, method: :patch, params: { clear_dates: true },
              class: "text-sm text-red-600 hover:text-red-500 font-medium cursor-pointer" %>
        <% end %>
      </div>
    <% end %>

    <% if @user.alert_start_date.present? && @user.alert_end_date.present? %>
      <div class="mt-4 rounded-lg bg-cyan-50 border border-cyan-200 p-3">
        <p class="text-sm text-cyan-800">
          You'll receive daily emails from
          <strong><%= @user.alert_start_date.strftime("%b %-d") %></strong> to
          <strong><%= @user.alert_end_date.strftime("%b %-d, %Y") %></strong>.
        </p>
      </div>
    <% end %>

    <hr class="my-6 border-slate-200">

    <div class="flex items-center justify-between">
      <%= link_to "Change Password", edit_user_registration_path, class: "text-sm text-cyan-600 hover:text-cyan-500 font-medium" %>
      <%= link_to "Log Out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-slate-500 hover:text-slate-700" %>
    </div>
  </div>
</div>
