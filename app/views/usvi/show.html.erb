<% meta title: "USVI Cruise Ship Schedule — St. Thomas & St. Croix Crowd Tracker",
       description: "Check the USVI cruise ship schedule for Charlotte Amalie (St. Thomas) and Frederiksted (St. Croix). See hourly crowd risk at Magens Bay, Sapphire and Coki Beaches, National Park Beaches, Rainbow Beach, and Buck Island.",
       keywords: "usvi cruise ship schedule, st thomas cruise ship schedule, charlotte amalie cruise ships, st croix cruise ship schedule, frederiksted cruise ships, magens bay crowded, coki beach crowds, trunk bay crowded" %>
<% meta og: { title: "USVI Cruise Ship Schedule & Crowd Tracker",
              description: "Track cruise ships visiting St. Thomas and St. Croix. Check hourly crowd risk at Magens Bay, Sapphire and Coki Beaches, and National Park Beaches.",
              type: "website",
              image: image_url("magens-bay.jpg") } %>

<% content_for :head do %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "USVI Cruise Ship Schedule",
  "description": "Track cruise ships visiting the US Virgin Islands. See hourly crowd risk levels at Magens Bay, Sapphire and Coki Beaches, National Park Beaches, Rainbow Beach, and Buck Island.",
  "url": "https://bvicruiseshipschedule.com/usvi",
  "applicationCategory": "TravelApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "dateModified": "<%= @last_scrape_at.iso8601 %>",
  "about": [
    { "@type": "TouristAttraction", "name": "Magens Bay", "address": { "@type": "PostalAddress", "addressLocality": "St. Thomas", "addressRegion": "US Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "Sapphire Beach", "address": { "@type": "PostalAddress", "addressLocality": "St. Thomas", "addressRegion": "US Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "Coki Beach", "address": { "@type": "PostalAddress", "addressLocality": "St. Thomas", "addressRegion": "US Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "National Park Beaches", "address": { "@type": "PostalAddress", "addressLocality": "St. John", "addressRegion": "US Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "Rainbow Beach", "address": { "@type": "PostalAddress", "addressLocality": "St. Croix", "addressRegion": "US Virgin Islands" } },
    { "@type": "TouristAttraction", "name": "Buck Island", "address": { "@type": "PostalAddress", "addressLocality": "St. Croix", "addressRegion": "US Virgin Islands" } }
  ]
}
</script>
<% end %>

<%# Hero %>
<div class="relative isolate overflow-hidden">
  <%= image_tag "magens-bay.jpg", class: "absolute inset-0 -z-10 size-full object-cover", alt: "Magens Bay, St. Thomas USVI" %>
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-slate-900/60 via-slate-900/45 to-slate-950/80"></div>
  <div class="mx-auto max-w-3xl px-6 py-24 sm:py-32 text-center">
    <h1 class="text-4xl font-semibold tracking-tight text-balance text-white sm:text-6xl">USVI Cruise Ship Schedule</h1>
    <p class="mt-6 text-lg font-medium text-pretty text-gray-200 sm:text-xl/8">
      Track cruise ships at <strong class="text-white">Charlotte Amalie</strong> and <strong class="text-white">Frederiksted</strong>.
      See hourly crowd risk at <strong class="text-white">Magens Bay</strong>, <strong class="text-white">Sapphire and Coki Beaches</strong>,
      <strong class="text-white">National Park Beaches</strong>, <strong class="text-white">Rainbow Beach</strong>, and <strong class="text-white">Buck Island</strong>.
    </p>
    <div class="mt-8 flex items-center justify-center gap-x-4">
      <a href="#schedule" class="rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400">View Schedule</a>
      <%= link_to root_path, class: "text-sm font-semibold text-white" do %>BVI Schedule <span aria-hidden="true">→</span><% end %>
    </div>
  </div>
</div>

<div class="mx-auto max-w-3xl px-4 mt-8 mb-8">

<%= render "shared/past_date_banner", start_date: @start_date, today: @today, today_url: usvi_path %>

<%= render "shared/timeline_legend" %>

<%# Port & Beach page cross-links %>
<div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6">
  <h3 class="text-sm font-semibold text-slate-700 mb-2">Port & Beach Forecasts</h3>
  <p class="text-xs text-slate-500 mb-3">Detailed schedules and crowd forecasts:</p>
  <div class="flex flex-wrap gap-2">
    <%= link_to "St. Thomas", st_thomas_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan-700 hover:bg-cyan-100 transition" %>
    <%= link_to "St. Croix", st_croix_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-cyan-50 text-cyan-700 hover:bg-cyan-100 transition" %>
    <%= link_to "Magens Bay", magens_bay_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 hover:bg-slate-200 transition" %>
    <%= link_to "Sapphire & Coki Beaches", coki_beach_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 hover:bg-slate-200 transition" %>
    <%= link_to "National Park Beaches", national_park_beaches_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 hover:bg-slate-200 transition" %>
    <%= link_to "Rainbow Beach", rainbow_beach_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 hover:bg-slate-200 transition" %>
    <%= link_to "Buck Island", buck_island_path, class: "inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-slate-100 text-slate-600 hover:bg-slate-200 transition" %>
  </div>
</div>

<%# BVI cross-link %>
<div class="relative rounded-xl overflow-hidden mb-6">
  <%= image_tag "north-sound-4.jpg", class: "absolute inset-0 size-full object-cover", alt: "North Sound, Virgin Gorda BVI" %>
  <div class="absolute inset-0 bg-gradient-to-r from-slate-900/85 via-slate-900/60 to-slate-900/40"></div>
  <div class="relative p-5 flex items-center justify-between">
    <div>
      <p class="text-base font-bold text-white">Also visiting the BVI?</p>
      <p class="text-sm text-gray-200">Track cruise ship crowds at The Baths, White Bay, and Cane Garden Bay.</p>
    </div>
    <%= link_to "BVI Schedule →", root_path, class: "shrink-0 rounded-md bg-white/90 px-4 py-2 text-xs font-semibold text-slate-900 hover:bg-white transition" %>
  </div>
</div>

<%= turbo_frame_tag "schedule" do %>
<div id="schedule"></div>

<%= render "shared/week_navigation",
  prev_url: usvi_path(start_date: @prev_week_start),
  next_url: usvi_path(start_date: @next_week_start),
  today_url: usvi_path,
  form_url: usvi_path,
  start_date: @start_date,
  end_date: @end_date,
  today: @today %>

<%= render "shared/share_button", url: "https://bvicruiseshipschedule.com#{request.path}?start_date=#{@start_date.iso8601}" %>

<% combined_visits_by_date = @dates.each_with_object({}) { |d, h| h[d] = (@st_thomas_visits_by_date[d] || []) + (@st_croix_visits_by_date[d] || []) } %>
<%= render "shared/week_overview",
  dates: @dates,
  visits_by_date: combined_visits_by_date,
  locations: @st_thomas_locations + @st_croix_locations,
  snapshots: @snapshots %>

<%# Day cards — USVI uses port-grouped layout %>
<div class="space-y-5">
  <% @dates.each do |date| %>
    <% st_thomas_visits = @st_thomas_visits_by_date[date] || [] %>
    <% st_croix_visits = @st_croix_visits_by_date[date] || [] %>
    <% all_visits = st_thomas_visits + st_croix_visits %>
    <% is_today = date == @today %>
    <% day_peak = all_visits.any? ? day_peak_intensity(date, @st_thomas_locations + @st_croix_locations, @snapshots) : nil %>

    <div class="bg-white rounded-xl shadow-sm border <%= is_today ? 'border-cyan-300 ring-2 ring-cyan-100' : 'border-slate-200' %> <%= "border-l-4 #{intensity_border_class(day_peak)}" if day_peak %> overflow-hidden">
      <div class="px-4 pt-4 <%= is_today ? 'bg-cyan-50/50' : '' %>">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-3">
            <div class="text-center min-w-[3rem]">
              <div class="text-xs font-medium text-slate-500 uppercase"><%= date.strftime("%a") %></div>
              <div class="text-2xl font-bold <%= is_today ? 'text-cyan-600' : 'text-slate-900' %>"><%= date.day %></div>
              <% if is_today %>
                <div class="text-[10px] font-semibold text-cyan-600 uppercase">Today</div>
              <% end %>
            </div>
            <div>
              <div class="text-sm font-medium text-slate-700"><%= date.strftime("%B %-d, %Y") %></div>
            </div>
          </div>
          <% if all_visits.any? %>
            <div class="text-right">
              <div class="text-3xl font-bold text-slate-900"><%= number_with_delimiter(total_passengers_for(all_visits)) %></div>
              <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Cruise Guests</div>
              <div class="text-xs text-slate-400"><%= all_visits.size %> ship<%= all_visits.size == 1 ? '' : 's' %> in port</div>
            </div>
          <% else %>
            <div class="text-right">
              <div class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">
                <span class="size-1.5 rounded-full bg-emerald-500"></span>
                Quiet day — no ships in port
              </div>
              <div class="mt-1 text-xs text-slate-400">Enjoy the beaches 🌴</div>
            </div>
          <% end %>
        </div>

        <%# === ST. THOMAS SECTION === %>
        <div class="mb-4">
          <div class="flex items-center gap-2 mb-2 pb-2 border-b border-slate-200">
            <span class="text-sm font-bold text-slate-700">St. Thomas</span>
            <span class="text-xs text-slate-400">Charlotte Amalie</span>
          </div>

          <% if st_thomas_visits.any? %>
            <div class="flex flex-wrap gap-x-4 gap-y-1 mb-3 text-xs text-slate-500">
              <%= st_thomas_visits.map { |v| "#{v.ship_name} (#{number_with_delimiter(v.passenger_capacity || 0)})" }.join(', ') %>
            </div>
          <% else %>
            <p class="text-xs text-slate-400 mb-3">No ships scheduled</p>
          <% end %>

          <% @st_thomas_locations.each do |location| %>
            <% snapshots = @snapshots[[date, location.id]] || [] %>
            <% peak = peak_intensity_for(snapshots) %>
            <%= render "shared/location_card", location: location, snapshots: snapshots, peak: peak %>
          <% end %>
        </div>

        <%# === ST. CROIX SECTION === %>
        <div class="mb-4">
          <div class="flex items-center gap-2 mb-2 pb-2 border-b border-slate-200">
            <span class="text-sm font-bold text-slate-700">St. Croix</span>
            <span class="text-xs text-slate-400">Frederiksted</span>
          </div>

          <% if st_croix_visits.any? %>
            <div class="flex flex-wrap gap-x-4 gap-y-1 mb-3 text-xs text-slate-500">
              <%= st_croix_visits.map { |v| "#{v.ship_name} (#{number_with_delimiter(v.passenger_capacity || 0)})" }.join(', ') %>
            </div>
          <% else %>
            <p class="text-xs text-slate-400 mb-3">No ships scheduled</p>
          <% end %>

          <% @st_croix_locations.each do |location| %>
            <% snapshots = @snapshots[[date, location.id]] || [] %>
            <% peak = peak_intensity_for(snapshots) %>
            <%= render "shared/location_card", location: location, snapshots: snapshots, peak: peak %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
<% end %>

<%# About section %>
<div id="how-it-works" class="mt-8 bg-white rounded-xl shadow-sm border border-slate-200 p-5">
  <h3 class="text-sm font-semibold text-slate-700 mb-2">How does this work?</h3>
  <div class="text-sm text-slate-500 space-y-2">
    <p>
      We pull published cruise ship schedules daily — ship names, passenger capacity, arrival and departure times,
      and which USVI port they're visiting. Then we estimate hourly crowd levels at popular beaches throughout each day.
    </p>
    <p>
      <strong>Magens Bay</strong>, <strong>Coki Beach</strong>, and <strong>Sapphire Beach</strong> get cruise traffic from ships at Charlotte Amalie (St. Thomas) —
      they're a short taxi ride from the cruise terminal.
      <strong>National Park Beaches</strong> (Trunk Bay, Maho Bay, Cinnamon Bay on St. John) get hit when Charlotte Amalie
      passengers take excursion boats or the Red Hook ferry to St. John.
    </p>
    <p>
      <strong>Rainbow Beach</strong> is steps from the Frederiksted cruise pier on St. Croix — it fills up fast on ship days.
      <strong>Buck Island</strong> gets cruise excursion boat traffic from Frederiksted, typically arriving about an hour after the ship docks.
    </p>
    <p>
      These are estimates based on published schedules and ship capacity. Real crowd levels depend on weather, excursion bookings,
      and actual occupancy. Use this as a planning tool — check the hourly bars and aim for green windows.
    </p>
  </div>
</div>

<%= render "shared/faq_section", faqs: build_faqs(:usvi, today_visits: @today_visits, today_passengers: @today_passengers, today: @today) %>

<%= render "shared/footer_attribution", utm_campaign: "footer_yw_usvi" %>

</div>
