<%# Locals: start_date, today, today_url %>
<% if start_date < today %>
<div class="mb-4 flex items-center justify-between gap-3 p-3 bg-amber-50 border border-amber-200 rounded-lg text-sm">
  <div class="text-amber-800">
    <strong class="font-semibold">Past forecast</strong> — viewing data for <%= start_date.strftime("%B %-d, %Y") %>.
  </div>
  <%= link_to today_url, class: "shrink-0 text-xs font-semibold text-amber-900 hover:text-amber-950 underline" do %>
    See today's forecast →
  <% end %>
</div>
<% end %>
