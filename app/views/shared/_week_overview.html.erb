<%# Locals: dates, visits_by_date, locations, snapshots %>
<% stats = week_overview_stats(dates, visits_by_date, locations, snapshots) %>
<% if stats %>
  <div class="grid grid-cols-3 gap-px bg-slate-200 rounded-xl overflow-hidden border border-slate-200 mb-6 shadow-sm">
    <div class="bg-white px-3 py-4 text-center">
      <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"><%= number_with_delimiter(stats[:passengers]) %></div>
      <div class="mt-0.5 text-[10px] sm:text-xs font-semibold text-slate-500 uppercase tracking-wide">Cruise Guests</div>
    </div>
    <div class="bg-white px-3 py-4 text-center">
      <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"><%= stats[:ships] %></div>
      <div class="mt-0.5 text-[10px] sm:text-xs font-semibold text-slate-500 uppercase tracking-wide">Ship Visits</div>
    </div>
    <div class="bg-white px-3 py-4 text-center">
      <div class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900"><%= stats[:busiest_date].strftime("%a %-m/%-d") %></div>
      <div class="mt-0.5 text-[10px] sm:text-xs font-semibold uppercase tracking-wide <%= intensity_text_color(stats[:busiest_peak]) %>">
        Busiest — <%= intensity_label(stats[:busiest_peak]) %> Risk
      </div>
    </div>
  </div>
<% end %>
