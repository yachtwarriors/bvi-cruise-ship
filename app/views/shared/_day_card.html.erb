<%# Locals: date, visits, locations, snapshots, today %>
<% is_today = date == today %>
<% day_peak = visits.any? ? day_peak_intensity(date, locations, snapshots) : nil %>

<div class="bg-white rounded-xl shadow-sm border <%= is_today ? 'border-cyan-300 ring-2 ring-cyan-100' : 'border-slate-200' %> <%= "border-l-4 #{intensity_border_class(day_peak)}" if day_peak %> overflow-hidden">
  <div class="px-4 pt-4 <%= is_today ? 'bg-cyan-50/50' : '' %>">
    <div class="flex items-start justify-between mb-3">
      <div class="flex items-center gap-3">
        <div class="text-center min-w-[3rem]">
          <div class="text-xs font-medium text-slate-500 uppercase"><%= date.strftime("%a") %></div>
          <div class="text-2xl font-bold <%= is_today ? 'text-cyan-600' : 'text-slate-900' %>"><%= date.day %></div>
          <% if is_today %>
            <div class="text-[10px] font-semibold text-cyan-600 uppercase">Today</div>
          <% end %>
        </div>
        <div>
          <div class="text-sm font-medium text-slate-700"><%= date.strftime("%B %-d, %Y") %></div>
        </div>
      </div>

      <% if visits.any? %>
        <div class="text-right">
          <div class="text-3xl font-bold text-slate-900"><%= number_with_delimiter(total_passengers_for(visits)) %></div>
          <div class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Cruise Guests</div>
          <div class="text-xs text-slate-400"><%= visits.size %> ship<%= visits.size == 1 ? '' : 's' %> in port</div>
        </div>
      <% else %>
        <div class="text-right">
          <div class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-emerald-700">
            <span class="size-1.5 rounded-full bg-emerald-500"></span>
            Quiet day — no ships in port
          </div>
          <div class="mt-1 text-xs text-slate-400">Enjoy the beaches 🌴</div>
        </div>
      <% end %>
    </div>

    <%# Ship detail — collapsed by default so the timeline stays the focus %>
    <% if visits.any? %>
      <details class="mb-3 group">
        <summary class="cursor-pointer list-none text-xs text-slate-500 hover:text-slate-700 flex items-center gap-1">
          <svg class="w-3 h-3 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <span><%= visits.size %> ship<%= visits.size == 1 ? '' : 's' %> — tap for arrival &amp; departure times</span>
        </summary>

        <div class="mt-2 overflow-x-auto">
          <table class="w-full text-xs text-left">
            <thead class="text-slate-400 border-b border-slate-200">
              <tr>
                <th class="py-1 pr-2 font-medium">Ship</th>
                <th class="py-1 pr-2 font-medium">Port</th>
                <th class="py-1 pr-2 font-medium whitespace-nowrap">In</th>
                <th class="py-1 pr-2 font-medium whitespace-nowrap">Out</th>
                <th class="py-1 font-medium text-right whitespace-nowrap">Guests</th>
              </tr>
            </thead>
            <tbody class="text-slate-600">
              <% visits.sort_by { |v| [v.arrival_at || Time.zone.now.beginning_of_day, v.ship_name] }.each do |v| %>
                <tr class="border-b border-slate-100 last:border-0">
                  <td class="py-1.5 pr-2 font-medium text-slate-700"><%= v.ship_name %></td>
                  <td class="py-1.5 pr-2 text-slate-500"><%= v.port.name.sub(', Tortola', '').sub(', Virgin Gorda', '').sub(', St. Thomas', '').sub(', St. Croix', '') %></td>
                  <td class="py-1.5 pr-2 whitespace-nowrap"><%= local_ship_time(v.arrival_at) || '—' %></td>
                  <td class="py-1.5 pr-2 whitespace-nowrap"><%= local_ship_time(v.departure_at) || '—' %></td>
                  <td class="py-1.5 text-right whitespace-nowrap"><%= number_with_delimiter(ship_guest_count(v)) %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </details>
    <% end %>

    <%# Location cards %>
    <% locations.each do |location| %>
      <% loc_snapshots = snapshots[[date, location.id]] || [] %>
      <% peak = peak_intensity_for(loc_snapshots) %>
      <%= render "shared/location_card", location: location, snapshots: loc_snapshots, peak: peak %>
    <% end %>
  </div>
</div>
