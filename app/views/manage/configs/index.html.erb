<h1 class="text-2xl font-bold text-gray-900 mb-6">Model Parameters</h1>
<p class="text-sm text-slate-500 mb-6">Tune the crowd estimation model. Changes take effect after recalculating.</p>

<div class="bg-white rounded-lg shadow-sm">
  <table class="w-full text-sm">
    <thead>
      <tr class="text-left text-slate-500 border-b">
        <th class="p-4">Parameter</th>
        <th class="p-4">Value</th>
        <th class="p-4">Description</th>
        <th class="p-4"></th>
      </tr>
    </thead>
    <tbody>
      <% @configs.each do |config| %>
        <tr class="border-b border-slate-100">
          <%= form_with model: config, url: manage_config_path(config), method: :patch do |f| %>
            <td class="p-4 font-mono text-xs text-slate-600"><%= config.key %></td>
            <td class="p-4">
              <%= f.text_field :value, class: "border border-slate-200 rounded px-2 py-1 text-sm w-24 focus:ring-2 focus:ring-cyan-500" %>
            </td>
            <td class="p-4 text-slate-400"><%= config.description %></td>
            <td class="p-4">
              <%= f.submit "Save", class: "px-3 py-1 bg-cyan-500 text-white rounded text-xs hover:bg-cyan-600 cursor-pointer transition" %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= button_to "Recalculate All Crowd Data", manage_recalculate_path, method: :post,
      class: "px-4 py-2 bg-cyan-500 text-white rounded-lg hover:bg-cyan-600 text-sm font-medium transition" %>
</div>
