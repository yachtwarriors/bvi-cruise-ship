<div class="mx-auto max-w-md px-4 mt-12 mb-12">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-xl font-bold text-slate-900 mb-2">Forgot Your Password?</h2>
    <p class="text-sm text-slate-500 mb-6">Enter your email and we'll send you a reset link.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }, class: "space-y-4") do |f| %>
      <% if resource.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-3">
          <% resource.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-700"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
      </div>

      <div>
        <%= f.submit "Send Reset Link", class: "w-full rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400 cursor-pointer transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-slate-500">
      <%= link_to "Back to login", new_user_session_path, class: "text-cyan-600 hover:text-cyan-500 font-medium" %>
    </div>
  </div>
</div>
