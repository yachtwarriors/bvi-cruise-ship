<div class="mx-auto max-w-md px-4 mt-12 mb-12">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-xl font-bold text-slate-900 mb-6">Log In</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-4") do |f| %>
      <% if flash[:alert] %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-3">
          <p class="text-sm text-red-700"><%= flash[:alert] %></p>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
      </div>

      <div class="flex items-center justify-between">
        <label class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "rounded border-slate-300 text-cyan-600 focus:ring-cyan-500" %>
          <span class="text-sm text-slate-600">Remember me</span>
        </label>
        <%= link_to "Forgot password?", new_user_password_path, class: "text-sm text-cyan-600 hover:text-cyan-500" %>
      </div>

      <div>
        <%= f.submit "Log In", class: "w-full rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400 cursor-pointer transition" %>
      </div>
    <% end %>

  </div>
</div>
