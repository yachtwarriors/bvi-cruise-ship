<div class="mx-auto max-w-md px-4 mt-12 mb-12">
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <h2 class="text-xl font-bold text-slate-900 mb-1">Create an Account</h2>
    <p class="text-sm text-slate-500 mb-6">Get daily crowd alerts for your BVI trip dates.</p>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-4") do |f| %>
      <% if resource.errors.any? %>
        <div class="rounded-lg bg-red-50 border border-red-200 p-3">
          <% resource.errors.full_messages.each do |message| %>
            <p class="text-sm text-red-700"><%= message %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
        <p class="text-xs text-slate-400 mt-1"><%= @minimum_password_length %> characters minimum</p>
      </div>

      <div>
        <%= f.label :password_confirmation, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password",
            class: "w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500" %>
      </div>

      <div>
        <%= f.submit "Sign Up", class: "w-full rounded-md bg-cyan-500 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-cyan-400 cursor-pointer transition" %>
      </div>
    <% end %>

    <div class="mt-4 text-center text-sm text-slate-500">
      Already have an account? <%= link_to "Log in", new_user_session_path, class: "text-cyan-600 hover:text-cyan-500 font-medium" %>
    </div>
  </div>
</div>
